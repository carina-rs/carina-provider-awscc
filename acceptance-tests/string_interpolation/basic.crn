provider awscc {
  region = awscc.Region.ap_northeast_1
}

let env = 'test'

let vpc = awscc.ec2.Vpc {
  cidr_block = '10.0.0.0/16'

  tags = {
    Name        = "interp-${env}-vpc"
    Environment = env
  }
}

awscc.ec2.Subnet {
  vpc_id            = vpc.vpc_id
  cidr_block        = '10.0.1.0/24'
  availability_zone = 'ap-northeast-1a'

  tags = {
    Name  = "interp-${env}-subnet"
    VpcId = "vpc-${vpc.vpc_id}"
  }
}
