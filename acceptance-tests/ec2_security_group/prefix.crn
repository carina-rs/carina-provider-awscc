# EC2 Security Group - group_name_prefix test
#
# Tests: group_name_prefix generates a unique name with prefix + random suffix,
#        plan-verify confirms state reconciliation preserves the generated name,
#        destroy cleans up the prefixed resource.

provider awscc {
  region = awscc.Region.ap_northeast_1
}

let vpc = awscc.ec2.Vpc {
  cidr_block = '10.0.0.0/16'
}

awscc.ec2.SecurityGroup {
  vpc_id            = vpc.vpc_id
  group_description = 'Acceptance test - group_name_prefix'
  group_name_prefix = 'carina-acc-test-'
}
