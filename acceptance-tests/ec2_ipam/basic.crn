# EC2 IPAM - Basic test
#
# Tests: tier, operating_regions, description, tags

provider awscc {
  region = awscc.Region.ap_northeast_1
}

awscc.ec2.Ipam {
  tier        = advanced
  description = 'Acceptance test IPAM'

  operating_region {
    region_name = 'ap-northeast-1'
  }

  tags = {
    Environment = 'acceptance-test'
  }
}
