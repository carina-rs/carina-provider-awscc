# EC2 VPC Gateway Attachment - VPN Gateway test
#
# Tests: vpn_gateway_id
# Requires: VPN Gateway

provider awscc {
  region = aws.Region.ap_northeast_1
}

let vpc = awscc.ec2.Vpc {
  cidr_block = '10.0.0.0/16'
}

let vpn_gw = awscc.ec2.VpnGateway {
  type = aws.ec2.VpnGateway.Type.ipsec_1
}

awscc.ec2.VpcGatewayAttachment {
  vpc_id         = vpc.vpc_id
  vpn_gateway_id = vpn_gw.vpn_gateway_id
}
