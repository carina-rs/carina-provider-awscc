provider awscc {
  region = awscc.Region.ap_northeast_1
}

let base_cidr = '10.0.0.0/16'

let vpc = awscc.ec2.vpc {
  cidr_block = base_cidr

  tags = {
    Name = 'cidr-subnet-test'
  }
}

awscc.ec2.subnet {
  vpc_id            = vpc.vpc_id
  cidr_block        = cidr_subnet(base_cidr, 8, 1)
  availability_zone = 'ap-northeast-1a'

  tags = {
    Name = 'cidr-subnet-test'
  }
}
