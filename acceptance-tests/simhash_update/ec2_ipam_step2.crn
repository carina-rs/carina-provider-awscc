# EC2 IPAM - SimHash reconciliation test (step 2)
#
# Tests: changing description on anonymous resource triggers in-place update
# (not delete+create) via SimHash Hamming distance reconciliation

provider awscc {
  region = awscc.Region.ap_northeast_1
}

awscc.ec2.ipam {
  description = 'simhash acceptance test updated'
  tier        = awscc.ec2.ipam.Tier.free

  tags = {
    Environment = 'acceptance-test'
    Purpose     = 'simhash-test'
  }
}
