# EC2 EIP - SimHash reconciliation test (step 1)
#
# Tests: anonymous resource (no create-only values set) can be created
# Case A: schema has create-only properties, but user didn't set any

provider awscc {
  region = awscc.Region.ap_northeast_1
}

awscc.ec2.eip {
  domain = "vpc"

  tags = {
    Environment = "acceptance-test"
    Purpose     = "simhash-test"
  }
}
