# S3 Bucket - bucket_name_prefix test
#
# Tests: bucket_name_prefix generates a unique name with prefix + random suffix,
#        plan-verify confirms state reconciliation preserves the generated name,
#        destroy cleans up the prefixed resource.

provider awscc {
  region = aws.Region.ap_northeast_1
}

awscc.s3.Bucket {
  bucket_name_prefix = 'carina-acc-test-'

  directives {
    force_delete = true
  }
}
