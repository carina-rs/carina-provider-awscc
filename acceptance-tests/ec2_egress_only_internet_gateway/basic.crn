# EC2 Egress Only Internet Gateway - Basic test
#
# Tests: vpc_id, tags

provider awscc {
  region = awscc.Region.ap_northeast_1
}

let vpc = awscc.ec2.Vpc {
  cidr_block = '10.0.0.0/16'
}

awscc.ec2.EgressOnlyInternetGateway {
  vpc_id = vpc.vpc_id

  tags = {
    Environment = 'acceptance-test'
  }
}
