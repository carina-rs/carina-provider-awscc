# Network with Route Table module
#
# Imports the network module (VPC + Subnet) and adds a route table.
# Demonstrates nested module imports.

let network = import "../network"

arguments {
  cidr_block : string
  subnet_cidr: string
  az         : string
}

let net = network {
  cidr_block  = cidr_block
  subnet_cidr = subnet_cidr
  az          = az
}

let rt = awscc.ec2.route_table {
  vpc_id = net.vpc_id

  tags = {
    Name = "nested-module-test-rt"
  }
}

attributes {
  vpc_id        : awscc.ec2.vpc = net.vpc_id
  route_table_id: awscc.ec2.route_table = rt.route_table_id
}
