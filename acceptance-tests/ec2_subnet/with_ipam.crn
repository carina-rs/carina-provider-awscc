# EC2 Subnet - IPAM test (resource planning pool)
#
# Tests: ipv4_ipam_pool_id, ipv4_netmask_length with proper IPAM hierarchy.
#
# AWS requires a resource planning pool (with SourceResource pointing to the VPC)
# for subnet CIDR allocation. This test creates:
#   1. STS caller identity (data source for account_id)
#   2. IPAM
#   3. Top-level IPAM Pool (provisioned with 10.0.0.0/8)
#   4. VPC (allocates /16 from top pool)
#   5. VPC-scoped IPAM Pool (resource planning pool with SourceResource = VPC)
#   6. Subnet (allocates /24 from VPC pool)
#
# Known issues:
# - IPAM Pool deletion times out via CloudControl API.

provider awscc {
  region = awscc.Region.ap_northeast_1
}

provider aws {
  region = aws.Region.ap_northeast_1
}

let identity = read aws.sts.caller_identity {}

let ipam = awscc.ec2.ipam {
  tier = advanced

  operating_region {
    region_name = "ap-northeast-1"
  }
}

let top_pool = awscc.ec2.ipam_pool {
  ipam_scope_id  = ipam.private_default_scope_id
  address_family = "IPv4"
  locale         = "ap-northeast-1"

  provisioned_cidr {
    cidr = "10.0.0.0/8"
  }
}

let vpc = awscc.ec2.vpc {
  ipv4_ipam_pool_id   = top_pool.ipam_pool_id
  ipv4_netmask_length = 16
}

let vpc_pool = awscc.ec2.ipam_pool {
  ipam_scope_id       = ipam.private_default_scope_id
  address_family      = "IPv4"
  locale              = "ap-northeast-1"
  source_ipam_pool_id = top_pool.ipam_pool_id

  source_resource = {
    resource_id     = vpc.vpc_id
    resource_owner  = identity.account_id
    resource_region = "ap-northeast-1"
    resource_type   = "vpc"
  }

  provisioned_cidr {
    cidr = vpc.cidr_block
  }
}

awscc.ec2.subnet {
  vpc_id              = vpc.vpc_id
  ipv4_ipam_pool_id   = vpc_pool.ipam_pool_id
  ipv4_netmask_length = 24
  availability_zone   = "ap-northeast-1a"

  tags = {
    Environment = "acceptance-test"
  }
}
