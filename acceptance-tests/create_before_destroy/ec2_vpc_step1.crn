# EC2 VPC - create_before_destroy without name_attribute (Step 1: Initial)
#
# VPC has no name_attribute, so create_before_destroy replacement should
# proceed without temporary name generation.

provider awscc {
  region = awscc.Region.ap_northeast_1
}

awscc.ec2.Vpc {
  cidr_block           = '10.200.0.0/16'
  enable_dns_support   = true
  enable_dns_hostnames = true

  tags = {
    Name        = 'carina-acc-test-cbd-vpc'
    Environment = 'acceptance-test'
  }
}
