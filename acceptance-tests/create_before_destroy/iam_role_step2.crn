# IAM Role - create_before_destroy temporary name test (Step 2: Replace)
#
# Changes path from "/" to "/carina/" (create-only property) with
# create_before_destroy lifecycle. This triggers replacement where:
# 1. New role is created with a temporary name (old role still exists)
# 2. Old role is deleted
# 3. New role is renamed back to "carina-acc-test-cbd-role"
#    (role_name is create-only so rename may not be possible via update)

provider awscc {
  region = aws.Region.ap_northeast_1
}

awscc.iam.Role {
  role_name = 'carina-acc-test-cbd-role'
  path      = '/carina/'

  directives {
    create_before_destroy = true
  }

  assume_role_policy_document = {
    version = awscc.iam.PolicyDocument.Version.2012_10_17
    statement {
      effect = awscc.iam.PolicyDocument.Statement.Effect.allow

      principal = {
        service = 'lambda.amazonaws.com'
      }

      action = 'sts:AssumeRole'
    }
  }
}
