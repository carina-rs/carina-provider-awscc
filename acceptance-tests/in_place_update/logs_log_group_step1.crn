# CloudWatch Logs Log Group - in-place update test (step 1)
#
# Tests: create log group with retention_in_days = 7

provider awscc {
  region = awscc.Region.ap_northeast_1
}

awscc.logs.LogGroup {
  log_group_name_prefix = '/carina/acc-test-update-'
  retention_in_days     = 7

  tags = {
    Environment = 'acceptance-test'
  }
}
