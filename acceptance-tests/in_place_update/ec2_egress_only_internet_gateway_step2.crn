# EC2 Egress Only Internet Gateway - in-place update test (step 2)
#
# Tests: update tags (in-place update)

provider awscc {
  region = awscc.Region.ap_northeast_1
}

let vpc = awscc.ec2.Vpc {
  cidr_block = '10.106.0.0/16'
}

awscc.ec2.EgressOnlyInternetGateway {
  vpc_id = vpc.vpc_id

  tags = {
    Environment = 'acceptance-test'
    UpdatedBy   = 'carina'
  }
}
