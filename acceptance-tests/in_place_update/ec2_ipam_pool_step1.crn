# EC2 IPAM Pool - in-place update test (step 1)
#
# Tests: create IPAM and IPAM pool with initial description

provider awscc {
  region = awscc.Region.ap_northeast_1
}

let ipam = awscc.ec2.Ipam {
  tier = advanced

  operating_region {
    region_name = 'ap-northeast-1'
  }
}

awscc.ec2.IpamPool {
  ipam_scope_id  = ipam.private_default_scope_id
  address_family = 'IPv4'
  locale         = 'ap-northeast-1'
  description    = 'in-place update test'

  tags = {
    Environment = 'acceptance-test'
  }
}
