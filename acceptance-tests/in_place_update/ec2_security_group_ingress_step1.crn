# EC2 Security Group Ingress - in-place update test (step 1)
#
# Tests: create ingress rule with initial description

provider awscc {
  region = awscc.Region.ap_northeast_1
}

let vpc = awscc.ec2.Vpc {
  cidr_block = '10.0.0.0/16'
}

let sg = awscc.ec2.SecurityGroup {
  vpc_id            = vpc.vpc_id
  group_description = 'carina acceptance test - ingress in-place update'
}

awscc.ec2.SecurityGroupIngress {
  group_id    = sg.group_id
  description = 'Allow HTTPS from VPC'
  ip_protocol = 'tcp'
  from_port   = 443
  to_port     = 443
  cidr_ip     = '10.0.0.0/16'
}
