# EC2 Route - IPv6 Egress Only Internet Gateway test
#
# Tests: destination_ipv6_cidr_block, egress_only_internet_gateway_id
# Requires: Egress Only Internet Gateway

provider awscc {
  region = awscc.Region.ap_northeast_1
}

let vpc = awscc.ec2.Vpc {
  cidr_block = '10.0.0.0/16'
}

let eoigw = awscc.ec2.EgressOnlyInternetGateway {
  vpc_id = vpc.vpc_id
}

let rt = awscc.ec2.RouteTable {
  vpc_id = vpc.vpc_id
}

awscc.ec2.Route {
  route_table_id                  = rt.route_table_id
  destination_ipv6_cidr_block     = '::/0'
  egress_only_internet_gateway_id = eoigw.id
}
