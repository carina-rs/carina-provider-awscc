# EC2 IPAM Example
#
# Creates an IP Address Manager (IPAM) instance.

provider awscc {
  region = awscc.Region.ap_northeast_1
}

awscc.ec2.ipam {
  description = 'Example IPAM'
  tier        = free

  operating_region {
    region_name = 'ap-northeast-1'
  }

  tags = {
    Environment = 'example'
  }
}
