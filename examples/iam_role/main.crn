# IAM Role Example
#
# Creates an IAM role that can be assumed by the Lambda service.

provider awscc {
  region = awscc.Region.ap_northeast_1
}

awscc.iam.Role {
  role_name = 'my-example-role'

  assume_role_policy_document = {
    version = '2012-10-17'
    statement {
      effect = 'Allow'

      principal = {
        service = 'lambda.amazonaws.com'
      }

      action = 'sts:AssumeRole'
    }
  }

  tags = {
    Environment = 'example'
  }
}
