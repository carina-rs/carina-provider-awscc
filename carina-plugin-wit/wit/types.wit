interface types {
    record resource-id {
        provider: string,
        resource-type: string,
        name: string,
    }

    /// Attribute values serialized as JSON strings for complex/nested types.
    variant value {
        bool-val(bool),
        int-val(s64),
        float-val(f64),
        str-val(string),
        /// JSON-encoded array
        list-val(string),
        /// JSON-encoded object
        map-val(string),
    }

    record state {
        identifier: option<string>,
        attributes: list<tuple<string, value>>,
        exists: bool,
    }

    record resource-def {
        id: resource-id,
        attributes: list<tuple<string, value>>,
    }
}
